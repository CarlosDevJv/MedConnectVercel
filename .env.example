# Copie para .env.local e preencha. Na Vercel: Project Settings → Environment Variables com os mesmos nomes.

# Deploy Vercel: se o repositório Git for a pasta que contém "mediconnect/", defina Root Directory = mediconnect em Project Settings → General.

VITE_SUPABASE_URL=https://yuanqfswhberkoevtmfr.supabase.co
# Substitua pela chave anon real do Supabase (Settings → API); o placeholder sb_publishable_xxx não funciona em runtime.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Local: porta do Vite. Produção na Vercel: opcional (no browser usa window.location.origin se vazio).
# Se definir, use https://seu-app.vercel.app ou seu domínio customizado para redirects Auth.
VITE_APP_URL=http://localhost:5173

# Supabase Auth → URL configuration (Site URL + Redirect URLs): inclua todas as bases (preview *.vercel.app, produção, domínio próprio).
# Caminhos usados em redirects pela app (como {APP_URL}<caminho>): /reset-password, /app (convites/links).
